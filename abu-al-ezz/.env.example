NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Public URL where the site is deployed (used for SEO metadata, sitemap & robots.txt)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Admin order email notifications (via Resend — https://resend.com)
# 1. Create a free Resend account at resend.com and get your API key
# 2. Set ADMIN_EMAIL to the address that receives new order alerts
# 3. For production, verify your domain in Resend and set RESEND_FROM_EMAIL
#    e.g. "Abu Al-Ezz <noreply@your-domain.com>"
#    Without a verified domain, Resend only sends to your own account email.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ADMIN_EMAIL=your-admin-email@example.com
RESEND_FROM_EMAIL=Abu Al-Ezz <noreply@your-domain.com>
